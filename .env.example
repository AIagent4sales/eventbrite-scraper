# Required — get your API key from https://spidra.io
SPIDRA_API_KEY=your_api_key_here

# The Eventbrite search URL to scrape
SEARCH_URL=https://www.eventbrite.com/d/tx--houston/lecture/

# Which pages to scrape (default: 1-2)
# Examples: "5" | "1-10" | "3,5,7" | "1-3,7,9-10"
PAGES=1-2

# Set to "true" to skip re-discovering event URLs and reuse the list from the last run.
# Useful when re-running enrichment after a partial or failed run.
SKIP_DISCOVERY=false
